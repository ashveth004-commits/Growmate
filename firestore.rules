rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return true; // Temporarily allow all for testing without Google Auth
    }

    function isOwner(userId) {
      let currentUserId = request.auth != null ? request.auth.uid : 'guest-123';
      return userId == currentUserId;
    }

    function isPlantOwner(plantId) {
      let currentUserId = request.auth != null ? request.auth.uid : 'guest-123';
      return get(/databases/$(database)/documents/plants/$(plantId)).data.ownerId == currentUserId;
    }

    function isValidUser(data) {
      return true;
    }

    function isValidPlant(data) {
      return data.keys().hasAll(['ownerId', 'name', 'species']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if true;
    }

    match /diaryEntries/{entryId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == (request.auth != null ? request.auth.uid : 'guest-123');
      allow create: if isAuthenticated() && request.resource.data.userId == (request.auth != null ? request.auth.uid : 'guest-123');
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) && (request.method != 'create' || isValidUser(request.resource.data));
    }

    match /plants/{plantId} {
      allow read, update, delete: if isAuthenticated() && resource.data.ownerId == (request.auth != null ? request.auth.uid : 'guest-123');
      allow create: if isAuthenticated() && isValidPlant(request.resource.data);

      match /schedules/{scheduleId} {
        allow read, write: if isPlantOwner(plantId);
      }
      match /fertilizerLogs/{logId} {
        allow read, write: if isPlantOwner(plantId);
      }
      match /wateringLogs/{logId} {
        allow read, write: if isPlantOwner(plantId);
      }
      match /healthIssues/{issueId} {
        allow read, write: if isPlantOwner(plantId);
      }
      match /timeline/{eventId} {
        allow read, write: if isPlantOwner(plantId);
      }
      match /insights/{insightId} {
        allow read, write: if isPlantOwner(plantId);
      }
      match /growthLogs/{logId} {
        allow read, write: if isPlantOwner(plantId);
      }
    }
  }
}
